{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CapsLock Pusher",
  "version": "0.1.0",
  "identifier": "com.wayvee.capslockpusher",
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "frontendDist": "../src",
    "devUrl": null
  },
  "app": {
    "windows": [
      {
        "title": "CapsLock Pusher",
        "width": 760,
        "height": 540,
        "resizable": false,
        "center": true
      }
    ],
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": false
    },
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.png"
    ]
  }
}
